# Copy to .env.local (do not commit secrets)
#
# Recommended (local): leave NEXT_PUBLIC_API_URL unset so the browser calls
# /api/... on the Next server; next.config.mjs rewrites that to FastAPI.
# Start API: from repo root, `npm run dev:api` or `cd backend && python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000`
#
# Optional: call FastAPI directly from the browser instead (must match CORS on the API).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
#
# If Next runs in Docker but the API is another service name, set where the Node server should proxy:
# BACKEND_URL=http://api:8000
