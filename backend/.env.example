# ── Database ─────────────────────────────────────────────────────────────────
# Leave empty to use SQLite (./shiksha_link.db) — sufficient for local dev
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/shiksha_link

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Groq API key for enhanced LangChain extraction (optional)
GROQ_API_KEY=your_groq_api_key_here

# Whisper model size: tiny | base | small | medium (default: base)
# WHISPER_MODEL=base

# SentenceTransformer model (default: all-MiniLM-L6-v2)
# SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# ── Telephony — Parent Voice AI ───────────────────────────────────────────────
# Get these from https://console.twilio.com
# Leave blank to run in demo-queue mode (no real calls placed)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── Maps ─────────────────────────────────────────────────────────────────────
# Override India GeoJSON source (optional)
# INDIA_STATES_GEOJSON_URL=https://...
